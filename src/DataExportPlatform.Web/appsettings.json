{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=DataExportPlatform;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "ExportSettings": {
    "OutputDirectory": "C:\\DataExports",
    "ArchiveRoot": "C:\\DataExports\\Archive",
    "AppDSourceFile": "C:\\DataSources\\appD_source.csv",
    "RetentionDays": 30,
    "JobRetention": {
      "AppA": 30,
      "AppB": 30,
      "AppC": 30,
      "AppD": 30
    }
  },
  "Authorization": {
    "ArchiveAdminGroup": "DOMAIN\\SG-DataExport-Admins",
    "ArchiveJobGroups": {
      "AppA": "DOMAIN\\SG-DataExport-AppA",
      "AppB": "DOMAIN\\SG-DataExport-AppB",
      "AppC": "DOMAIN\\SG-DataExport-AppC",
      "AppD": "DOMAIN\\SG-DataExport-AppD"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
