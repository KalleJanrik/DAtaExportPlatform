@page
@model DataExportPlatform.Web.Pages.IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<h1 class="mb-4">Pipeline Dashboard</h1>

@if (!Model.Runs.Any())
{
    <div class="alert alert-info">No pipeline runs yet. <a href="/Runs/Trigger">Trigger a run</a> to get started.</div>
}
else
{
    <table class="table table-hover">
        <thead class="table-dark">
            <tr>
                <th>#</th>
                <th>Started At</th>
                <th>Finished At</th>
                <th>Status</th>
                <th>Exports</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var run in Model.Runs)
            {
                <tr>
                    <td>@run.Id</td>
                    <td>@run.StartedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</td>
                    <td>@(run.FinishedAt.HasValue ? run.FinishedAt.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss") : "—")</td>
                    <td>
                        <span class="badge @BadgeClass(run.Status)">@run.Status</span>
                    </td>
                    <td>@run.ExportLogs.Count</td>
                    <td><a href="/Runs/Detail?id=@run.Id" class="btn btn-sm btn-outline-primary">Detail</a></td>
                </tr>
            }
        </tbody>
    </table>
}

<a href="/Runs/Trigger" class="btn btn-success mt-3">Trigger Manual Run</a>
<a href="/Overrides/Index" class="btn btn-secondary mt-3 ms-2">Manage Overrides</a>

@functions {
    static string BadgeClass(DataExportPlatform.Core.Models.PipelineStatus status) => status switch
    {
        DataExportPlatform.Core.Models.PipelineStatus.Running        => "bg-primary",
        DataExportPlatform.Core.Models.PipelineStatus.Success        => "bg-success",
        DataExportPlatform.Core.Models.PipelineStatus.PartialFailure => "bg-warning text-dark",
        DataExportPlatform.Core.Models.PipelineStatus.Failed         => "bg-danger",
        _ => "bg-secondary"
    };
}
