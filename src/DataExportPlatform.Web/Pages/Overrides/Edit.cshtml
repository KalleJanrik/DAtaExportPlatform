@page
@model DataExportPlatform.Web.Pages.Overrides.EditModel
@{
    ViewData["Title"] = Model.IsNew ? "New Override" : "Edit Override";
}

<h1>@ViewData["Title"]</h1>

<form method="post" class="mt-3" style="max-width: 600px;">
    <input type="hidden" asp-for="Override.Id" />

    <div class="mb-3">
        <label class="form-label">Costcenter</label>
        <select asp-for="Override.CostcenterId" class="form-select">
            <option value="">— Select —</option>
            @foreach (var cc in Model.AvailableCostcenters)
            {
                <option value="@cc.Id">[@cc.Code] @cc.Name</option>
            }
        </select>
        <span asp-validation-for="Override.CostcenterId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Responsible User Email</label>
        <input asp-for="Override.ResponsibleUserEmail" class="form-control" placeholder="user@example.com" />
        <span asp-validation-for="Override.ResponsibleUserEmail" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Reason (optional)</label>
        <textarea asp-for="Override.Reason" class="form-control" rows="3"></textarea>
    </div>

    @if (Model.ValidationErrors.Any())
    {
        <div class="alert alert-danger">
            <ul class="mb-0">
                @foreach (var err in Model.ValidationErrors)
                {
                    <li>@err</li>
                }
            </ul>
        </div>
    }

    <button type="submit" class="btn btn-primary">Save</button>
    <a href="/Overrides/Index" class="btn btn-secondary ms-2">Cancel</a>
</form>
