@page
@model DataExportPlatform.Web.Pages.Archive.JobModel
@{
    ViewData["Title"] = $"Archive — {Model.AppId}";
}

<div class="d-flex align-items-center mb-4 gap-3">
    <a href="/Archive" class="btn btn-sm btn-outline-secondary">← Archive</a>
    <h1 class="mb-0">@Model.AppId</h1>
</div>

@if (!Model.Days.Any())
{
    <div class="alert alert-info">No archived days found for @Model.AppId.</div>
}
else
{
    <div class="accordion" id="daysAccordion">
        @foreach (var (day, index) in Model.Days.Select((d, i) => (d, i)))
        {
            var collapseId = $"collapse-{index}";
            var headingId = $"heading-{index}";
            var expanded = index == 0;

            <div class="accordion-item">
                <h2 class="accordion-header" id="@headingId">
                    <button class="accordion-button @(expanded ? "" : "collapsed")"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#@collapseId"
                            aria-expanded="@(expanded ? "true" : "false")"
                            aria-controls="@collapseId">
                        @day
                        <span class="badge bg-secondary ms-2">@day.Files.Count file(s)</span>
                    </button>
                </h2>
                <div id="@collapseId"
                     class="accordion-collapse collapse @(expanded ? "show" : "")"
                     aria-labelledby="@headingId"
                     data-bs-parent="#daysAccordion">
                    <div class="accordion-body p-0">
                        <table class="table table-sm table-striped mb-0">
                            <thead class="table-dark">
                                <tr>
                                    <th>File</th>
                                    <th>Size</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var file in day.Files)
                                {
                                    <tr>
                                        <td><code>@file.FileName</code></td>
                                        <td>@file.SizeBytes.ToString("N0") B</td>
                                        <td>
                                            <a href="/Archive/Job?appId=@Model.AppId&day=@day.Day&file=@file.FileName&handler=Download"
                                               class="btn btn-sm btn-outline-primary">
                                                Download
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    </div>
}
