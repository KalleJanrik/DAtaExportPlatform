@page
@model DataExportPlatform.Web.Pages.Archive.IndexModel
@{
    ViewData["Title"] = "Archive";
}

<h1 class="mb-4">Archive</h1>

@if (!Model.Jobs.Any())
{
    <div class="alert alert-info">No archived files found. Run the pipeline first.</div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var job in Model.Jobs)
        {
            <div class="col">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">@job.AppId</h5>
                        <p class="card-text text-muted mb-1">@job.DayCount day(s) &nbsp;·&nbsp; @job.FileCount file(s)</p>
                        @if (job.LatestDay is not null)
                        {
                            <p class="card-text"><small class="text-muted">Latest: @job.LatestDay</small></p>
                        }
                    </div>
                    <div class="card-footer">
                        <a href="/Archive/Job?appId=@job.AppId" class="btn btn-sm btn-primary">Browse</a>
                    </div>
                </div>
            </div>
        }
    </div>
}
